       <property name="styleSheet">
        <string notr="true">/* 槽 */
QSlider::groove:horizontal {
    border: none;
    height: 8px;
    background: rgba(170, 170, 170, 100);
    border-radius: 4px;
}

/* 已播放 */
QSlider::sub-page:horizontal {
    background: white;
    border-radius: 4px;
}

/* 未播放 */
QSlider::add-page:horizontal {
    background: rgba(170, 170, 170, 100);
    border-radius: 4px;
}

/* 滑块（默认状态-纯圆） */
QSlider::handle:horizontal {
    background: white;
    width: 12px;
    border-radius: 4px;
}
</string>
