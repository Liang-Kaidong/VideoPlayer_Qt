       <property name="styleSheet">
        <string notr="true">/* 槽 */
QSlider::groove:vertical {
    border: none;
    width: 8px;   /* ⭐ 横向是 height，这里变 width */
    background: rgba(170, 170, 170, 100);
    border-radius: 4px;
}

/* 已播放（下 → 上） */
QSlider::add-page:vertical {
    background: white;
	border-radius: 4px;
}

/* 未播放（上 → 下） */
QSlider::sub-page:vertical {
    background: rgba(170, 170, 170, 100);
    border-radius: 4px;
}

/* 滑块（小圆点） */
QSlider::handle:vertical {
    background: white;
    height: 12px;   /* ⭐ 横向是 width，这里变 height */
    border-radius: 4px;
}</string>
       </property>
