       <property name="styleSheet">
        <string notr="true">QListWidget#playListWidget {
    border: none;
    background-color: transparent;
	color: white;
}

/* 默认项 */
QListWidget#playListWidget::item {
    padding: 8px;
    border-radius: 6px;
	margin-bottom: 4px;
}

/* 鼠标悬停 */
QListWidget#playListWidget::item:hover {
    background-color: rgba(176, 176, 176, 50);
}

/* 选中状态（重点） */
QListWidget#playListWidget::item:selected {
    background-color: rgb(52, 130, 255);
    color: white;
}</string>
